; https://editorconfig.org/

root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
indent_size = 4
trim_trailing_whitespace = false

[Dockerfile]
indent_size = 4

[*.py]
indent_size = 4

[{*.sh,*.bash}]
indent_size = 4

[{*.just,*.justfile}]
indent_size = 4

[{Makefile,*.mk}]
indent_style = tab
indent_size = 4

[{*.go,go.mod,go.sum}]
indent_style = tab
indent_size = 4

[.gitmodules]
indent_style = tab
indent_size = 4
